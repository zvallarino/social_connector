# Copy this file to .env and fill in your credentials
# No-key connectors (NIH PubMed, ClinicalTrials.gov, Crossref, Wikipedia) need nothing here.

# X (Twitter)
TWITTER_BEARER_TOKEN=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Instagram
INSTAGRAM_ACCESS_TOKEN=

# TikTok
TIKTOK_ACCESS_TOKEN=
# Optional override (defaults to https://open.tiktokapis.com)
TIKTOK_API_BASE=

# YouTube
YOUTUBE_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=
